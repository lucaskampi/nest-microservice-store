{
  "name": "nest-microservice-store",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS Microservices Store - Portfolio Project",
  "workspaces": [
    "packages/shared",
    "auth",
    "backend",
    "gateway",
    "supplier",
    "carrier"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:auth": "npm run dev -w auth",
    "dev:store": "npm run dev -w backend",
    "dev:supplier": "npm run dev -w supplier",
    "dev:carrier": "npm run dev -w carrier",
    "dev:gateway": "npm run dev -w gateway",
    "dev:all": "concurrently \"npm:dev:auth\" \"npm:dev:store\" \"npm:dev:supplier\" \"npm:dev:carrier\" \"npm:dev:gateway\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
